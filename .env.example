# Consensus - Environment Variables Example
# Copy this file to .env.local if you want to set default values
#
# Recommended: use server-side API keys (see server section below).
# Client-side keys are optional overrides for OpenRouter only.

# (Optional) OpenRouter API Key override (client-side)
# Get your key from: https://openrouter.ai/keys
# VITE_OPENROUTER_API_KEY=your_api_key_here

# === Server-side API Keys (backend proxy) ===
# These are used by server/index.js
# OPENROUTER_API_KEY=your_openrouter_key
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# GEMINI_API_KEY=your_gemini_key
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_MAX_TOKENS=64000
# Prompt cache tuning (optional)
# Set PROMPT_CACHE_ENABLED=false to disable provider prompt-cache hints.
# Omit PROMPT_CACHE_TTL for provider defaults; set 1h for longer Claude/OpenRouter Claude cache TTL.
# PROMPT_CACHE_ENABLED=true
# PROMPT_CACHE_TTL=1h
# Optional OpenAI retention hint for supported models: in_memory or 24h.
# The UI spelling in-memory is also accepted and normalized server-side.
# OPENAI_PROMPT_CACHE_RETENTION=24h
# Direct Gemini explicit cachedContent tuning. The UI can override these per browser profile.
# GEMINI_PROMPT_CACHE_EXPLICIT_ENABLED=true
# GEMINI_PROMPT_CACHE_TTL_SECONDS=300
# GEMINI_PROMPT_CACHE_MAX_ENTRIES=80
# Serialize the first matching long request so parallel duplicates can reuse the provider cache.
# PROMPT_CACHE_WARMUP_SERIALIZATION=true
# OPENROUTER_REFERER=http://localhost:5173
# OPENROUTER_TITLE=Consensus
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_DOC_MODEL=gpt-4.1-mini
# ANTHROPIC_DOC_MODEL=claude-sonnet-4-5
# GEMINI_DOC_MODEL=gemini-2.5-flash
# OPENROUTER_DOC_MODEL=google/gemini-2.0-flash-001
# GEMINI_YOUTUBE_MODEL=gemini-2.5-flash
# DOC_GENERATION_MAX_BYTES=12582912
# PDF_OCR_PAGE_MAX_BYTES=3145728
# PDF_OCR_TOTAL_MAX_BYTES=14680064
# PDF_OCR_MAX_PAGES=8
# MULTIMODAL_MAX_ATTACHMENTS=16
# MULTIMODAL_MAX_JOB_POLL_MS=45000
# MULTIMODAL_JOB_TTL_MS=3600000
# ARTIFACT_TTL_MS=86400000
# ARTIFACT_STORE_DIR=./server/.artifacts

# Default Models (optional - these are the defaults used in the app)
# VITE_DEFAULT_DEBATE_MODELS=anthropic/claude-sonnet-4.5,openai/gpt-5.2,google/gemini-3-pro-preview
# VITE_DEFAULT_SYNTHESIS_MODEL=anthropic/claude-sonnet-4.5
# VITE_DEFAULT_CONVERGENCE_MODEL=anthropic/claude-sonnet-4.5

# Web Search (optional - enable by default)
# VITE_DEFAULT_WEB_SEARCH=false
# OpenRouter web search server-tool tuning (optional)
# OPENROUTER_WEB_SEARCH_ENGINE=auto
# OPENROUTER_WEB_SEARCH_MAX_RESULTS=5
# OPENROUTER_WEB_SEARCH_MAX_TOTAL_RESULTS=15
# OPENROUTER_WEB_SEARCH_CONTEXT_SIZE=medium
# OPENROUTER_WEB_SEARCH_ALLOWED_DOMAINS=arxiv.org,nature.com
# OPENROUTER_WEB_SEARCH_EXCLUDED_DOMAINS=reddit.com
# OPENROUTER_WEB_SEARCH_USER_LOCATION={"type":"approximate","city":"New York","region":"New York","country":"US","timezone":"America/New_York"}

# Max Debate Rounds (optional)
# VITE_MAX_DEBATE_ROUNDS=5

# Stream stall watchdog (optional, client-side, milliseconds; minimum 15000)
# If no stream data arrives within this window, the request is cancelled so it can be retried.
# VITE_STREAM_STALL_TIMEOUT_MS=90000

# Stream render throttle (optional, client-side, milliseconds; range 0-250)
# Reduces UI re-render pressure during token streaming. Set to 0 for unthrottled updates.
# VITE_STREAM_RENDER_THROTTLE_MS=40

# Cost fallback pricing (optional, client-side)
# Used only when provider response is missing usage.cost.
# JSON object format:
# {
#   "openai/gpt-5.2": { "inputPerMillion": 1.25, "outputPerMillion": 10.0 },
#   "anthropic/*": { "inputPerMillion": 3.0, "outputPerMillion": 15.0 },
#   "default": { "inputPerMillion": 2.0, "outputPerMillion": 8.0 }
# }
# VITE_MODEL_PRICING_FALLBACKS={"openai/gpt-5.2":{"inputPerMillion":1.25,"outputPerMillion":10.0}}
#
# Optional runtime override in browser localStorage:
# key: model_pricing_fallbacks
# value: same JSON format as above
